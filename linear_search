"""Поиск экстремумов (линейный поиск) и сортировка месяцев."""

from prefix_stats import MONTH_NAMES


def find_hottest_and_coldest(dates, temps):  # одним проходом находит дни с макс. и мин. температурой
    hottest_index = 0
    coldest_index = 0

    for i in range(1, len(temps)):
        if temps[i] > temps[hottest_index]:
            hottest_index = i
        if temps[i] < temps[coldest_index]:
            coldest_index = i

    hottest = (dates[hottest_index], temps[hottest_index])
    coldest = (dates[coldest_index], temps[coldest_index])
    return hottest, coldest


def sort_months_by_temp(averages):  # сортировка вставками пар (название месяца, средняя температура) по возрастанию
    items = []
    for i in range(12):
        items.append((MONTH_NAMES[i], averages[i]))

    for i in range(1, len(items)):
        current = items[i]
        j = i - 1
        while j >= 0 and items[j][1] > current[1]:
            items[j + 1] = items[j]
            j -= 1
        items[j + 1] = current

    return items
